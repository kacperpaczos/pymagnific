# Magnific REST API - https://www.magnific.com/developers/dashboard
MAGNIFIC_API_KEY=

# Webhook HMAC secret from API dashboard (not a URL)
MAGNIFIC_WEBHOOK_SECRET=

# Optional public webhook URL for apps run (e.g. ngrok)
MAGNIFIC_WEBHOOK_URL=

# MCP OAuth - tokens: ~/.config/pymagnific/oauth.json
# Login: pymagnific auth login (device flow, opens browser)
# MAGNIFIC_OAUTH_SCOPES=openid profile email offline_access mcp:custom-audience
# MAGNIFIC_OAUTH_DEVICE_TIMEOUT=300
